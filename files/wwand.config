# wwand configuration example.
#
# wwand has NO /etc/config/wwand file — all configuration lives in
# /etc/config/network (WireGuard-style). This file is documentation only; it is
# not installed. Existing /etc/config/wwand configs keep working (the daemon
# reads them for compatibility) and are auto-converted on upgrade by the
# uci-defaults migrator (/usr/libexec/wwand/migrate).
#
# The network-native model (in /etc/config/network):
#
# config wwand_modem 'm0'          # the modem: hardware + SIM slot + radio
#	option device 'wwan0'           # netdev name, or /dev/cdc-wdm0
#	# option path '1-1.2'           # optional: pin to a fixed USB topology path
#	                                #   (like a wifi-device `path`; usb_path still ok)
#	option pincode '1234'           # default SIM PIN
#	option sim_slot '1'             # primary physical slot (0 = leave as-is)
#	option modes 'lte,nr5g'         # lte umts gsm nr5g td-scdma cdma / all
#	option mcc '262'                # manual PLMN (optional)
#	option mnc '01'
#	option mux 'auto'               # auto|rmnet|qmimux|none
#	# list lock_4g 'earfcn:pci'     # cell lock (optional)
#
# config wwand_sim 'vodafone'      # OPTIONAL per-SIM override, matched by ICCID
#	option iccid '89490...'         # (option modem is optional — leave empty to
#	option pincode '5678'           #  match this card in any modem)
#	option apn 'web.vodafone.de'
#
# config interface 'wan'           # the connection
#	option proto 'wwand'            # wwand's netifd proto, all backends (legacy
#	                                #  'qmi' still accepted for back-compat)
#	option modem 'm0'
#	option apn 'internet'           # empty -> SIM override / network default
#	option pdp_type 'ipv4v6'        # ipv4|ipv6|ipv4v6
#	option auth 'none'              # none|pap|chap|both
#	# option mux_id '1'             # QMAP channel for a second context (0 = none)
#
# config wwand_globals 'globals'
#	option log_level 'info'         # err|warn|notice|info|debug
