#!/usr/bin/env ucode
// wwand — migrate old configs to the network-native model (everything in
// /etc/config/network: wwand_modem + interface `option modem` + connection).
//
// Converts:
//   - stock OpenWrt `proto mbim` (umbim) / `proto ncm` (comgt-ncm) interfaces —
//     these stop working once wwand-mbim/-ncm replace the stock handler, so they
//     MUST be rewritten to `proto qmi` (wwand's proto) for netifd to invoke us;
//   - wwand legacy inline `proto qmi` interfaces.
// Already network-native interfaces are left alone; the daemon keeps reading any
// wwand format (compat), so migrating is safe to run repeatedly.
//
// Without arguments this prints the proposed uci changes (dry run); pass
// --apply to write them. Also invoked once on install/upgrade from the
// uci-defaults script.

'use strict';

import * as libuci from 'uci';
import * as config from 'wwand.config';

const apply = (ARGV[0] == '--apply');

let cursor = libuci.cursor();
let raw = { network: cursor.get_all('network') };

let changes = config.migrate_plan(raw);

if (!length(changes)) {
	print("nothing to migrate: config is already network-native (or has nothing to convert)\n");
	exit(0);
}

// --- print (dry run) ---------------------------------------------------------
for (let c in changes) {
	// c = [ op, 'network', section, option|null, value ]
	if (c[0] == 'add')
		printf("uci set network.%s=%s\n", c[2], c[4]);
	else if (c[0] == 'set')
		printf("uci set network.%s.%s='%s'\n", c[2], c[3], c[4]);
	else if (c[0] == 'add_list')
		printf("uci add_list network.%s.%s='%s'\n", c[2], c[3], c[4]);
	else if (c[0] == 'delete')
		printf("uci delete network.%s.%s\n", c[2], c[3]);
}

if (!apply) {
	printf("\n(dry run — re-run with --apply to write, then: /etc/init.d/wwand reload; ubus call network reload)\n");
	exit(0);
}

// --- apply -------------------------------------------------------------------
for (let c in changes) {
	if (c[0] == 'add')
		cursor.set('network', c[2], c[4]);        // create typed section
	else if (c[0] == 'set')
		cursor.set('network', c[2], c[3], c[4]);
	else if (c[0] == 'add_list') {
		let cur = cursor.get('network', c[2], c[3]) ?? [];

		if (type(cur) != 'array')
			cur = (cur != null) ? [ cur ] : [];

		push(cur, c[4]);
		cursor.set('network', c[2], c[3], cur);
	}
	else if (c[0] == 'delete')
		cursor.delete('network', c[2], c[3]);
}

cursor.commit('network');

printf("\napplied. run: /etc/init.d/wwand reload; ubus call network reload\n");
