#!/bin/sh
# wwand-esim — SM-DP+ profile download / notifications via lpac. lpac's stdio
# APDU driver is bridged to the wwand ubus APDU channel: lpac writes requests
# {"type":"apdu","payload":{"func":..,"param":hex}} to its stdout and reads
# replies {"type":"apdu","payload":{"ecode":n,"data":hex}} from its stdin (for
# logic_channel_open the ecode carries the channel). lpac does the SM-DP+ HTTPS
# itself (curl) over the router's uplink — no modem APN involved.
#
# Bridge topology: lpac's stdout is piped into the demux loop; lpac's stdin is a
# single 'back' fifo held open read-write here (fd 5) so neither side blocks on
# open (paired fifos deadlock on the open ordering). Replies are written to fd 5.
#
# Usage: [OP=download|chip|notif-list|notif-process] wwand-esim-download \
#          <modem> <slot> [activation_code] [confirmation]

MODEM="$1"
SLOT="$2"
CODE="$3"
CONF="$4"
OP="${OP:-download}"

# use the real binary: the OpenWrt /usr/bin/lpac wrapper forces LPAC_APDU=uqmi
LPAC_BIN=/usr/lib/lpac
[ -x "$LPAC_BIN" ] || LPAC_BIN="$(command -v lpac)"
[ -n "$LPAC_BIN" ] || { echo "lpac not installed" >&2; exit 90; }
[ -n "$MODEM" ] && [ -n "$SLOT" ] || { echo "usage: $0 <modem> <slot> [code] [conf]" >&2; exit 91; }

case "$OP" in
chip)          set -- chip info ;;
notif-list)    set -- notification list ;;
notif-process) set -- notification process -a ;;   # ack all pending to SM-DP+
*)
	[ -n "$CODE" ] || { echo "no activation code" >&2; exit 91; }
	set -- profile download -a "$CODE" ${CONF:+-c "$CONF"}
	;;
esac

echo ">> lpac $*" >&2

DIR="$(mktemp -d)" || exit 92
trap 'rm -rf "$DIR"' EXIT
mkfifo "$DIR/back" || exit 92

# hold the back fifo open read-write so lpac's stdin open never blocks and the
# fifo never sees EOF while we are running
exec 5<>"$DIR/back"

reply() {
	printf '{"type":"apdu","payload":{"ecode":%s,"data":"%s"}}\n' "$1" "$2" >&5
	[ -n "$WWAND_ESIM_DEBUG" ] && echo "dbg< reply ecode=$1 data=$2" >&2
}

CHAN=0

# lpac stdin <- back fifo (our replies via fd 5); lpac stdout -> demux loop
LPAC_APDU=stdio LPAC_HTTP=curl "$LPAC_BIN" "$@" <"$DIR/back" | while read -r line; do
	[ -n "$WWAND_ESIM_DEBUG" ] && echo "dbg> $line" >&2
	type="$(echo "$line" | jsonfilter -e '@.type' 2>/dev/null)"

	case "$type" in
	apdu)
		func="$(echo "$line" | jsonfilter -e '@.payload.func' 2>/dev/null)"
		param="$(echo "$line" | jsonfilter -e '@.payload.param' 2>/dev/null)"

		case "$func" in
		connect|disconnect)
			reply 0 ""
			;;
		logic_channel_open)
			out="$(ubus -t 30 call wwand modem_apdu \
				"{\"modem\":\"$MODEM\",\"op\":\"open\",\"slot\":$SLOT,\"aid\":\"$param\"}" 2>/dev/null)"
			CHAN="$(echo "$out" | jsonfilter -e '@.channel' 2>/dev/null)"
			if [ -n "$CHAN" ]; then reply "$CHAN" ""; else reply -1 ""; fi
			;;
		logic_channel_close)
			ubus -t 30 call wwand modem_apdu \
				"{\"modem\":\"$MODEM\",\"op\":\"close\",\"slot\":$SLOT,\"channel\":${CHAN:-0}}" >/dev/null 2>&1
			reply 0 ""
			;;
		transmit)
			out="$(ubus -t 60 call wwand modem_apdu \
				"{\"modem\":\"$MODEM\",\"op\":\"send\",\"slot\":$SLOT,\"channel\":${CHAN:-0},\"apdu\":\"$param\"}" 2>/dev/null)"
			data="$(echo "$out" | jsonfilter -e '@.response' 2>/dev/null)"
			if [ -n "$data" ]; then reply 0 "$data"; else reply -1 ""; fi
			;;
		*)
			reply -1 ""
			;;
		esac
		;;
	progress)
		msg="$(echo "$line" | jsonfilter -e '@.payload.message' 2>/dev/null)"
		pct="$(echo "$line" | jsonfilter -e '@.payload.progress' 2>/dev/null)"
		echo "progress: ${msg:-step}${pct:+ ($pct%)}" >&2
		;;
	lpa)
		code="$(echo "$line" | jsonfilter -e '@.payload.code' 2>/dev/null)"
		msg="$(echo "$line" | jsonfilter -e '@.payload.message' 2>/dev/null)"
		echo "result: code=${code:-?} ${msg}" >&2
		echo "$line" | jsonfilter -e '@.payload.data' 2>/dev/null | grep -q . && \
			echo "data: $(echo "$line" | jsonfilter -e '@.payload.data' 2>/dev/null)" >&2
		;;
	*)
		[ -n "$line" ] && echo "$line" >&2
		;;
	esac
done

exec 5>&-
