# wwand configuration.
#
# Old-style 'proto qmi' interfaces in /etc/config/network (without an
# 'option context') keep working through the built-in compat layer; new
# setups should use the explicit modem/context model below.
#
# config interface 'wan'          # in /etc/config/network
#	option proto 'qmi'
#	option context 'wan_ctx'
#
# config modem 'm0'
#	option device '/dev/cdc-wdm0'  # or: option netdev 'wwan0'
#	                               # or: option usb_path '1-1.2' (stable for multi-modem)
#	option pincode '1234'
#	option modes 'lte,nr5g'        # lte umts gsm nr5g td-scdma cdma / all
#	option mcc '262'               # manual network selection (optional)
#	option mnc '01'
#	option mux 'auto'              # auto|rmnet|qmimux|none
#	option dl_datagram_max_size '0'  # 0 = board quirk table
#	option tty ''                  # AT port override (autodetected)
#	list at_init 'AT+QMBNCFG="AutoSel",1'
#	option location '0'
#	option delay '0'
#	option failreboot '100'        # recovery ladder ceiling, 0 = never reboot
#	option zero_rx_timeout '21600'
#
# config context 'wan_ctx'
#	option modem 'm0'
#	option mux_id '0'              # 0 = no mux (wwan0), N > 0 = wwan0mN
#	option apn 'internet'          # or '#2' to use modem profile 2 untouched
#	option pdp_type 'ipv4v6'       # ipv4|ipv6|ipv4v6
#	option auth 'both'             # none|pap|chap|both
#	option username ''
#	option password ''
#	option mtu ''
#	option use_pushed_mtu '1'

config wwand 'globals'
	option log_level 'info'
