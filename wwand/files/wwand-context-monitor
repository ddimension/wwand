#!/bin/sh
# wwand — lean context supervisor, spawned by the proto shim via
# proto_run_command. A long-poll against the daemon: context_wait blocks until
# the daemon reports this interface's context down/errored, or answers
# 'keepalive' after its window if the context is still up. We loop on
# keepalive and exit on anything else; when we exit, netifd tears the interface
# down and re-runs the protocol setup.
#
# Why a bounded long-poll instead of a single indefinite call: ubusd does not
# track forwarded invokes, so a caller blocked on a provider that dies waits
# FOREVER (the monitor would hang and netifd would never re-establish the
# context). With a bounded client timeout, a wwand crash makes this call return
# within the timeout and we recover; on a graceful restart the daemon answers
# all parked waiters immediately. Either way no monitor ever hangs permanently.
#
# The client timeout must be larger than the daemon's keepalive window so a
# healthy context is refreshed by a 'keepalive' reply and never trips the
# timeout.

interface="$1"

[ -n "$interface" ] || exit 1

while :; do
	reply="$(ubus -t 45 call wwand context_wait "{\"interface\":\"$interface\"}" 2>/dev/null)" || exit 1

	case "$reply" in
		*'"keepalive"'*) ;;   # still connected — keep watching
		*) exit 1 ;;          # down / error / gone / unexpected -> let netifd retry
	esac
done
